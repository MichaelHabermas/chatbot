{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Static file server (Python)",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8080"],
      "port": 8080
    },
    {
      "name": "Static file server (npx serve)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "-l", "8080", "."],
      "port": 8080
    }
  ]
}
